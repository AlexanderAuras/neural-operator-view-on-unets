{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "python": "${command:python.interpreterPath}",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "pythonArgs": [ "-Wd" ],
            "justMyCode": false,
            "args": [],
            "env": {
                "CUBLAS_WORKSPACE_CONFIG": ":4096:8",
            },
        },
        {
            "name": "Python Debugger: Train",
            "type": "debugpy",
            "python": "${command:python.interpreterPath}",
            "request": "launch",
            "program": "${workspaceFolder}/fun/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "pythonArgs": [ "-O" ],
            "args": [
                "--debug",
                "--dataset=ellipses",
                "--model=classic",
                "--batch-size=32",
                "--max-epochs=10",
                //"--no-compile",
                "--device=cuda",
                "--num-workers=0",
            ],
            "env": {
                "CUBLAS_WORKSPACE_CONFIG": ":4096:8",
                "LD_LIBRARY_PATH": "${env:LD_LIBRARY_PATH}:/home/alexander/anaconda3/envs/FNO-UNet/lib/python3.11/site-packages/nvidia/cufft/lib",
            },
        },
    ],
}