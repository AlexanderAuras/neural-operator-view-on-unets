{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Tensorboard",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {},
            },
            "command": "${command:python.interpreterPath}",
            "args":[
                "-c",
                "\"import tensorboard.main; tensorboard.main.run_main()\"",
                "--samples_per_plugin=SCALARS=10000",
                "--logdir=${workspaceFolder}/runs",
            ],
            "problemMatcher": [],
        },
        {
            "label": "WeightVizWiz",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {},
            },
            "command": "${command:python.interpreterPath}",
            "args": [
                "${workspaceFolder}/WeightVizWiz/wvw/__main__.py",
            ],
            "problemMatcher": [],
        },
        {
            "label": "Generate data",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "CUBLAS_WORKSPACE_CONFIG": ":4096:8",
                    "LD_LIBRARY_PATH": "${env:LD_LIBRARY_PATH}:/home/alexander/anaconda3/envs/FNO-UNet/lib/python3.11/site-packages/nvidia/cufft/lib:/home/aa609734/.conda/envs/FNO-UNet/lib/python3.11/site-packages/nvidia/cufft/lib",
                },
            },
            "command": "${command:python.interpreterPath}",
            "args": [
                "${workspaceFolder}/fun/data/gen_data.py",
                "${input:n}",
                "${input:output_dir}",
                "--dataset=${input:dataset}",
                "--device=cuda"
            ],
            "problemMatcher": [],
        }
    ],
    "inputs": [
        {
            "id": "dataset",
            "type": "pickString",
            "description": "Select the dataset to generate test data for",
            "options": [
                "ellipses",
            ],
            "default": "ellipses",
        },
        {
            "id": "output_dir",
            "type": "promptString",
            "description": "Select the directory to save the generated test data to",
            "default": "${workspaceFolder}/data",
        },
        {
            "id": "n",
            "type": "promptString",
            "description": "Enter the mount of samples to generate",
            "default": "2000",
        }
    ]
}